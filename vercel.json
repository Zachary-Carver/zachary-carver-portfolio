{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/assets/zachary-carver-headshot-hq.svg",
      "destination": "/assets/zachary-carver-headshot-hq.jpg",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/assets/zachary-carver-headshot-hq.jpg",
      "destination": "/api/headshot"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {"key": "X-Content-Type-Options", "value": "nosniff"},
        {"key": "Referrer-Policy", "value": "strict-origin-when-cross-origin"},
        {"key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()"},
        {"key": "X-Frame-Options", "value": "DENY"}
      ]
    }
  ]
}
